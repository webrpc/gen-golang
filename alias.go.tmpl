{{- define "alias" -}}

{{- $name := .Name -}}
{{- $type := .Type -}}
{{- $typeMap := .TypeMap -}}
{{- $keywordMap := .KeywordMap -}}
{{- $typePrefix := .TypePrefix -}}
{{- $typeMeta := .TypeMeta -}}

{{- $goType := "" -}}
{{- $goImport := "" -}}
{{- range $meta := $typeMeta -}}
    {{- if exists $meta "go.type" -}}
        {{- $goType = get $meta "go.type" -}}
    {{- end -}}
    {{- if exists $meta "go.type.import" -}}
        {{- $goImport = get $meta "go.type.import" -}}
    {{- end -}}
{{- end }}

{{- /* If go.type has no package prefix and go.type.import is set, prepend the package name. */ -}}
{{- if and (ne $goType "") (ne $goImport "") (not (contains "." $goType)) -}}
    {{- $goType = printf "%s.%s" (base $goImport) $goType -}}
{{- end }}

type {{$typePrefix}}{{$name}} {{if ne $goType ""}}{{$goType}}{{else -}}
{{- template "field" dict "Type" $type "TypeMap" $typeMap "KeywordMap" $keywordMap "TypePrefix" $typePrefix "TypeMeta" $typeMeta -}}
{{- end}}
{{- end -}}
