		{{ $goFieldName }} {{template "field" dict "Name" $bf.Name "Type" $bf.Type "Optional" $bf.Optional "TypeMap" $typeMap "KeywordMap" $keywordMap "TypePrefix" $typePrefix "TypeMeta" $bf.Meta "JsonTags" true}}
	{{- end }}
	}{
	{{- range $j, $bf := $method.BodyFields}}
		{{- $goFieldName := firstLetterToUpper $bf.Name -}}
		{{- range $meta := $bf.Meta -}}
			{{- if exists $meta "go.field.name" -}}
				{{- $goFieldName = get $meta "go.field.name" -}}
			{{- end -}}
		{{- end }}
		{{- if $j}},{{end}} {{$reqVar}}.{{$goFieldName}}
	{{- end }},
	}
	{{ end -}}
	{{- else if $method.Succinct -}}
	{{- $inputVar = (index $method.Inputs 0).Name -}}
	{{- else if $method.Inputs | len}}
	{{- $inputVar = "in"}}
	in := struct {
	{{- range $i, $input := $method.Inputs}}
		Arg{{$i}} {{template "field" dict "Name" $input.Name "Type" $input.Type "Optional" $input.Optional "TypeMap" $typeMap "KeywordMap" $keywordMap "TypePrefix" $typePrefix "TypeMeta" $input.Meta "JsonTags" true}}
