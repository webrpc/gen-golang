func (r *{{firstLetterToLower $method.Name}}StreamReader) Read() ({{template "field" dict "Name" $output.Name "Type" $output.Type "Optional" $output.Optional "TypeMap" $typeMap "TypePrefix" $typePrefix "TypeMeta" $output.Meta}}, error) {
