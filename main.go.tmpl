{{- define "main" -}}

{{- /* Options with default values. */ -}}
{{- $opts := dict -}}
{{- set $opts "pkg" (default .Opts.pkg "proto") -}}
{{- set $opts "client" (ternary (in .Opts.client "" "true") true false) -}}
{{- set $opts "server" (ternary (in .Opts.server "" "true") true false) -}}
{{- set $opts "types" (ternary (eq (default .Opts.types "true") "false") false true) -}}
{{- set $opts "json" (default .Opts.json "stdlib") -}}
{{- set $opts "importTypesFrom" (default .Opts.importTypesFrom "" ) -}}
{{- set $opts "fixEmptyArrays" (ternary (in .Opts.fixEmptyArrays "" "true") true false) -}}
{{- set $opts "errorStackTrace" (ternary (in .Opts.errorStackTrace "" "true") true false) -}}
{{- set $opts "webrpcHeader" (ternary (eq (default .Opts.webrpcHeader "true") "false") false true) -}}

{{- /* Print help on -help. */ -}}
{{- if exists .Opts "help" -}}
  {{- template "help" $opts -}}
  {{- exit 0 -}}
{{- end -}}

{{- /* Print help on unsupported option. */ -}}
{{- range $k, $v := .Opts }}
  {{- if not (exists $opts $k) -}}
    {{- stderrPrintf "-%v=%q is not supported target option\n\nUsage:\n" $k $v -}}
    {{- template "help" $opts -}}
    {{- exit 1 -}}
  {{- end -}}
{{- end -}}

{{- if ne .WebrpcVersion "v1" -}}
  {{- stderrPrintf "%s generator error: unsupported webrpc version %s\n" .WebrpcTarget .WebrpcVersion -}}
  {{- exit 1 -}}
{{- end -}}

{{- if not (minVersion .WebrpcGenVersion "v0.9.0") -}}
  {{- stderrPrintf "%s generator error: unsupported webrpc-gen version %s, please update\n" .WebrpcTarget .WebrpcGenVersion -}}
  {{- exit 1 -}}
{{- end -}}

{{- /* Maps Go keywords. */ -}}
{{- $keywordMap := dict -}}
{{- set $keywordMap "type" true -}}
{{- set $keywordMap "case" true -}}
{{- set $keywordMap "chan" true -}}
{{- set $keywordMap "const" true -}}
{{- set $keywordMap "continue" true -}}
{{- set $keywordMap "default" true -}}
{{- set $keywordMap "defer" true -}}
{{- set $keywordMap "else" true -}}
{{- set $keywordMap "fallthrough" true -}}
{{- set $keywordMap "for" true -}}
{{- set $keywordMap "func" true -}}
{{- set $keywordMap "go" true -}}
{{- set $keywordMap "goto" true -}}
{{- set $keywordMap "if" true -}}
{{- set $keywordMap "import" true -}}
{{- set $keywordMap "interface" true -}}
{{- set $keywordMap "map" true -}}
{{- set $keywordMap "package" true -}}
{{- set $keywordMap "range" true -}}
{{- set $keywordMap "return" true -}}
{{- set $keywordMap "select" true -}}
{{- set $keywordMap "struct" true -}}
{{- set $keywordMap "switch" true -}}
{{- set $keywordMap "type" true -}}
{{- set $keywordMap "var" true -}}

{{- /* Map webrpc core types to Go. */ -}}
{{- $typeMap := dict -}}
{{- set $typeMap "null" "struct{}" -}}
{{- set $typeMap "any" "interface{}" -}}
{{- set $typeMap "byte" "byte" -}}
{{- set $typeMap "bool" "bool" -}}
{{- set $typeMap "uint" "uint" -}}
{{- set $typeMap "uint8" "uint8" -}}
{{- set $typeMap "uint16" "uint16" -}}
{{- set $typeMap "uint32" "uint32" -}}
{{- set $typeMap "uint64" "uint64" -}}
{{- set $typeMap "bigint" "BigInt" -}}
{{- set $typeMap "int" "int" -}}
{{- set $typeMap "int8" "int8" -}}
{{- set $typeMap "int16" "int16" -}}
{{- set $typeMap "int32" "int32" -}}
{{- set $typeMap "int64" "int64" -}}
{{- set $typeMap "float32" "float32" -}}
{{- set $typeMap "float64" "float64" -}}
{{- set $typeMap "string" "string" -}}
{{- set $typeMap "timestamp" "time.Time" -}}

{{- /* Determine if BigInt helpers are needed. */ -}}

{{- $usesBigInts := SchemaBigIntFieldsByType .WebRPCSchema -}}

{{/* INIT */}}
{{- $typePrefix := (last (split "/" $opts.importTypesFrom)) -}}
{{- if ne $typePrefix "" -}}
  {{- $typePrefix = (printf "%s." $typePrefix) -}}
{{- end -}}

{{- set $opts "" false -}}
{{- range $_, $service := .Services -}}
	{{- range $_, $method := $service.Methods -}}
		{{ if eq $method.StreamOutput true -}}
			{{- set $opts "streaming" true -}}
		{{- end -}}
	{{- end -}}
{{- end }}

{{- /* Allow using custom JSON configuration. */ -}}
{{- $json := "json" -}}
{{- if or (eq $opts.json "jsoniter") (eq $opts.json "sonic") -}}
  {{- $json = "jsonCfg" -}}
{{- end -}}
{{- /* End INIT */ -}}

// {{.SchemaName}} {{.SchemaVersion}} {{.SchemaHash}}
// --
// Code generated by webrpc-gen@{{.WebrpcGenVersion}} with {{.WebrpcTarget}} generator. DO NOT EDIT.
//
// {{.WebrpcGenCommand}}
package {{get $opts "pkg"}}

{{template "imports" dict "Types" .Types "Opts" $opts }}

{{/* Client/server version helpers. */}}
{{- if or $opts.client $opts.server }}

// WebRPC description and code-gen version
func WebRPCVersion() string {
	return "{{.WebrpcVersion}}"
}

// Schema version of your RIDL schema
func WebRPCSchemaVersion() string {
	return "{{.SchemaVersion}}"
}

// Schema hash generated from your RIDL schema
func WebRPCSchemaHash() string {
	return "{{.SchemaHash}}"
}

{{- "\n" -}}

{{end}}

{{/* Client interface */}}
{{ if $opts.client }}
{{ template "clientInterface" dict "BasePath" .BasePath "Services" .Services "TypeMap" $typeMap "KeywordMap" $keywordMap "Json" $json "Opts" $opts "TypePrefix" $typePrefix }}
{{ end -}}

{{- "\n" -}}

{{/* Server interface */}}
{{- if $opts.server }}
{{ template "serverInterface" dict "Services" .Services "TypeMap" $typeMap "KeywordMap" $keywordMap "TypePrefix" $typePrefix "Json" $json "Opts" $opts }}
{{ end -}}

{{- "\n" -}}

{{/* Schema types */}}
{{- if eq $opts.importTypesFrom "" }}
{{ template "types" dict "Services" .Services "Types" .Types "TypeMap" $typeMap "KeywordMap" $keywordMap "TypePrefix" $typePrefix "Opts" $opts }}
{{ end -}}

{{- "\n" -}}

{{/* Client */}}
{{- if $opts.client }}
{{ template "client" dict "BasePath" .BasePath "Services" .Services "TypeMap" $typeMap "KeywordMap" $keywordMap "Json" $json "Opts" $opts "TypePrefix" $typePrefix }}
{{ end -}}

{{- "\n" -}}

{{/* Server */}}
{{- if $opts.server }}
{{ template "server" dict "BasePath" .BasePath "Services" .Services "TypeMap" $typeMap "KeywordMap" $keywordMap "TypePrefix" $typePrefix "Json" $json "Opts" $opts }}
{{ template "webrpcMethods" dict "BasePath" .BasePath "Services" .Services }}
{{ end -}}

{{- "\n" -}}

{{/* Client helpers */}}
{{- if $opts.client }}
{{ template "clientHelpers" dict "Json" $json "Opts" $opts }}
{{ end -}}

{{/* Client/server helpers */}}
{{- if or $opts.client $opts.server }}
{{ template "helpers" dict "Opts" $opts }}

{{- if $usesBigInts}}
{{ template "bigintHelpers" dict "Schema" .WebRPCSchema "Services" .Services "Opts" $opts }}
{{ end -}}

{{/* Errors */}}
{{ template "errors" dict "WebrpcErrors" .WebrpcErrors "SchemaErrors" .Errors "Opts" $opts "TypePrefix" $typePrefix }}

{{ template "webrpcHeader" dict "Opts" $opts "WebrpcHeader" .WebrpcHeader }}
{{ template "jsonEncoders" dict "Opts" $opts }}
{{ end }}

{{- end }}
