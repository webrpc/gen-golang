{{define "types"}}
{{- $keywordMap := .KeywordMap -}}
{{- $typeMap := .TypeMap -}}
{{- $typePrefix := .TypePrefix -}}
{{- $types := .Types -}}
{{- $services := .Services -}}
{{- $opts := .Opts -}}

//
// Schema types
//
{{ range $_, $type := $types -}}

{{- if eq $type.Kind "enum" }}
	{{- if eq $type.Type.Expr "string" }}
{{template "enumString" dict "Name" $type.Name "Type" $type.Type "TypePrefix" $typePrefix "Fields" $type.Fields "Opts" $opts}}
	{{- else }}
{{template "enum" dict "Name" $type.Name "Type" $type.Type "TypePrefix" $typePrefix "Fields" $type.Fields "Opts" $opts}}
	{{- end -}}
{{ end -}}

{{- if and (eq $type.Kind "alias") $opts.types }}
{{- if gt (len $type.Comments) 0 }}
	{{- range $_, $comment := $type.Comments }}
		// {{ replaceAll $comment "\"" "'" }}
	{{- end }}
{{- end }}
{{template "alias" dict "Name" $type.Name "Type" $type.Type "TypeMap" $typeMap "KeywordMap" $keywordMap "TypePrefix" $typePrefix "TypeMeta" $type.Meta}}
{{ end -}}

{{- if and (eq $type.Kind "struct") $opts.types }}
{{- if gt (len $type.Comments) 0 }}
	{{- range $_, $comment := $type.Comments }}
		// {{ replaceAll $comment "\"" "'" }}
	{{- end }}
{{- end }}
{{template "struct" dict "Name" $type.Name "TypeMap" $typeMap "KeywordMap" $keywordMap "TypePrefix" $typePrefix "Fields" $type.Fields}}
{{ end -}}

{{- end }}

{{- end -}}
